{
  "name": "opendesign",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:backend": "bun --filter @opendesign/backend dev",
    "dev:pages": "bun --filter @opendesign/pages dev",
    "deploy": "turbo run deploy",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.5"
  }
}
